# ── QuantumBridge backend environment variables ───────────────────────────────

# Anthropic (existing)
ANTHROPIC_API_KEY=

# Server port (Render injects this automatically)
PORT=8000

# Debug mode (set to "true" for local hot-reload)
DEBUG=true

# ── Notion Integration ────────────────────────────────────────────────────────
# Create an internal integration at https://www.notion.so/my-integrations
# and share each database with it.
NOTION_API_KEY=
NOTION_FINDINGS_DB_ID=
NOTION_TASKS_DB_ID=
NOTION_AUDIT_DB_ID=
NOTION_PROJECT_DB_ID=

# ── ArmorIQ Integration ───────────────────────────────────────────────────────
ARMORIQ_API_KEY=
ARMORIQ_PROJECT_ID=
ARMORIQ_POLICY_ID=
